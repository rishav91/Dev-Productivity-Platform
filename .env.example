DATABASE_URL=postgresql://devplatform:devplatform@localhost:5432/devplatform
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=dev-productivity-platform

# ── LLM provider ────────────────────────────────────────────────────────────
# LLM_PROVIDER controls which backend runs hypothesize + synthesize nodes.
# Options: anthropic (default) | openai | groq | ollama
LLM_PROVIDER=anthropic

# Optional: override the default model for the chosen provider.
# Defaults per provider:
#   anthropic → claude-sonnet-4-20250514   ($3/$15 per MTok in/out)
#   openai    → gpt-4o-mini                ($0.15/$0.60 — ~20× cheaper)
#   groq      → groq/llama-3.3-70b-versatile  (free tier, rate-limited)
#   ollama    → ollama/llama3.2            (free, needs Ollama running locally)
# LLM_MODEL=

# API keys — only the key for your chosen provider is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
# Ollama needs no key; set OLLAMA_API_BASE if not running on localhost:11434.
# OLLAMA_API_BASE=http://localhost:11434

# ── Embedding provider ───────────────────────────────────────────────────────
# EMBED_PROVIDER controls how vectors are computed for pgvector retrieval.
# Switching providers changes the vector dimension — re-run `python fixtures/seed_db.py`.
# Options: openai (default) | ollama | local
EMBED_PROVIDER=openai

# Optional: override the default embedding model.
# Defaults per provider:
#   openai  → openai/text-embedding-3-small  (1536 dims, $0.02/MTok — nearly free)
#   ollama  → ollama/nomic-embed-text        (768 dims, free local)
#   local   → local/all-MiniLM-L6-v2        (384 dims, free — pip install sentence-transformers)
# EMBED_MODEL=

# Phase 2 — not needed for MVP
# GITHUB_TOKEN=
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# SLACK_BOT_TOKEN=
